# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=botnode
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Admin tokens (REQUIRED — no defaults)
BOTNODE_ADMIN_TOKEN=
ADMIN_KEY=

# JWT RSA keys (REQUIRED — paste PEM content)
BOTNODE_JWT_PRIVATE_KEY=
BOTNODE_JWT_PUBLIC_KEY=

# Internal skill communication key (REQUIRED)
INTERNAL_API_KEY=

# Redis
REDIS_URL=redis://redis:6379/0
