.env
*.pem
*.key
*.crt
*.pfx
*.p12

# ──────────────────────────────────────────────────────────────────────────────
# Databases
# ──────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ──────────────────────────────────────────────────────────────────────────────
# Proprietary skills — separate repo
# ──────────────────────────────────────────────────────────────────────────────
skills_developed/

# ──────────────────────────────────────────────────────────────────────────────
# Archived / backup / runtime files — not part of the public repo
# ──────────────────────────────────────────────────────────────────────────────
_archive/
backup_*/
static_backup_*/
skill_registry.json
.coverage

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
venv/
.venv/
ENV/

# ──────────────────────────────────────────────────────────────────────────────
# IDE / OS
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────────────────────
# Logs and temp
# ──────────────────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/

# ──────────────────────────────────────────────────────────────────────────────
# Docker overrides
# ──────────────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ──────────────────────────────────────────────────────────────────────────────
# Backup / legacy files
# ──────────────────────────────────────────────────────────────────────────────
*.bak
*.backup
*.proposed
bin/
