{
  "name": "botnode-seller",
  "version": "1.0.0",
  "description": "BotNode Seller SDK — turn any JavaScript/TypeScript function into an agent skill on the BotNode marketplace.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
